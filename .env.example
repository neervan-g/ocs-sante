# =============================================================================
# Production (recommended): Docker + SQLite on NAS — full billing + inventory
# =============================================================================
# Use docker-compose.yml (pull from Docker Hub) or docker-compose.local.yml (build locally).
# Do NOT set DATABASE_URL or USE_POSTGRES=true on the NAS app container.
#
# Required in production: comma-separated allow-list of browser origins. The
# server REFUSES TO START in NODE_ENV=production without this set (or
# CLIENT_ORIGIN for a single origin). Same-origin requests (e.g. the SPA
# bundled with the API) bypass this check automatically.
# CLIENT_ORIGINS=https://ocsvp.com,https://staff.ocsvp.com,https://ins.ocsvp.com
# Or a single origin:
# CLIENT_ORIGIN=https://staff.ocsvp.com

# Set to "production" when running on the NAS / behind a public tunnel so
# helmet headers tighten and the CORS guard above is enforced.
# NODE_ENV=production

# Optional: per-IP API throttle ceiling (requests per minute). Defaults to
# 600 which is generous for a clinic-scale deploy; lower it if you need
# tighter abuse control. /api/auth/login is always limited to 10 attempts
# per 15 minutes per IP regardless of this value.
# API_RATE_LIMIT_PER_MINUTE=600

# Your public Docker Hub username.
DOCKERHUB_USERNAME=your-dockerhub-username

# Docker Hub repository name for this app image.
APP_IMAGE_NAME=clinicflow

# LAN port on the NAS that will expose the website.
APP_PORT=8080

# Match the clinic timezone so reports and schedules line up.
TZ=Indian/Mauritius

# Web Push (VAPID) — run `npm run generate-vapid` in server/ to create a key pair.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@ocs.local

# How often Watchtower checks Docker Hub for a newer image, in seconds.
WATCHTOWER_POLL_INTERVAL=300

# Upsert base consumables from ocsMasterStockData.js on each app start. Must be literal "true" to enable.
# Keep false on production NAS after go-live.
SEED_OCS_MASTER_STOCK=false

# Mirror OCS master stock into every doctor bag on each app start. Must be literal "true" to enable.
# Keep false on production unless rebuilding all doctor bags from OCS.
SEED_DOCTOR_STOCK_FROM_OCS=false

# Consumable extension rows are auto-inserted on startup and first inventory load (insert-only).
# Does not restore IM/IV/Wound/Oral/Pediatric/Investigation after a category purge.

# One-time go-live warehouse reset (destructive). Wipes OCS master stock, all inventory
# activity/movement logs, TEST* placeholder rows, then re-seeds ocsMasterStockData.js.
# ALLOW_DB_PURGE=true npm run purge:ocs-warehouse --prefix server
# Docker: docker exec -e ALLOW_DB_PURGE=true clinicflow-app node src/scripts/purgeAndReseedOcsWarehouse.js
# ALLOW_DB_PURGE=false

# --- Cloudflare (optional; use one tunnel type only) ---

# Quick tunnel only: upstream URL inside Docker (default matches app service name).
CLOUDFLARE_TUNNEL_URL=http://clinicflow-app:3001

# Named tunnel (custom domain): token from Cloudflare Zero Trust → Networks → Tunnels → your tunnel → Docker install command.
# Used by docker-compose.cloudflare.named.yml only.
TUNNEL_TOKEN=

# --- Vercel frontend-only (API on NAS) — set in Vercel project Environment Variables ---
# VITE_API_BASE=https://your-public-nas-or-tunnel-host/api
# Do not deploy /api serverless when using NAS backend (see docs/NAS_SQLITE_PRODUCTION.md).
