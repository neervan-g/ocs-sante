{
  "name": "clinic-management-server",
  "version": "1.0.0",
  "description": "Express API for clinic management",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "test": "node --test \"tests/**/*.test.js\"",
    "generate-vapid": "node -e \"const webpush=require('web-push'); const keys=webpush.generateVAPIDKeys(); console.log('VAPID_PUBLIC_KEY='+keys.publicKey); console.log('VAPID_PRIVATE_KEY='+keys.privateKey);\"",
    "seed:ocs-stock": "node src/scripts/seedOcsMasterStock.js",
    "seed:ocs-consumables": "node src/scripts/seedOcsConsumablesExtension.js",
    "seed:ocs-im-drugs": "node src/scripts/seedOcsIMDrugsExtension.js",
    "seed:ocs-iv-drugs": "node src/scripts/seedOcsIVDrugsExtension.js",
    "seed:ocs-investigations": "node src/scripts/seedOcsInvestigationsExtension.js",
    "seed:ocs-wound-dressing": "node src/scripts/seedOcsWoundDressingExtension.js",
    "seed:ocs-pediatric-drugs": "node src/scripts/seedOcsPediatricDrugsExtension.js",
    "seed:ocs-oral-drugs": "node src/scripts/seedOcsOralDrugsExtension.js",
    "purge:ocs-test-items": "node src/scripts/purgeOcsTestInventory.js",
    "purge:test-items": "node src/scripts/purgeOcsTestInventory.js",
    "purge:ocs-warehouse": "node src/scripts/purgeAndReseedOcsWarehouse.js",
    "purge:ocs-categories": "node src/scripts/purgeOcsInventoryCategories.js",
    "purge:ocs-non-consumable": "node src/scripts/purgeOcsNonConsumableAll.js",
    "purge:ocs-consumable": "node src/scripts/purgeOcsConsumableStock.js",
    "setup:ocs-baseline": "node src/scripts/setupOcsStockBaseline.js",
    "purge:doctor-bag-categories": "node src/scripts/purgeDoctorBagCategories.js",
    "audit:inventory-categories": "node src/scripts/auditInventoryCategories.js",
    "dedupe:ocs-master": "node -e \"require('./src/db').initializeDatabase(); const r=require('./src/lib/dedupeOcsMasterInventory').prepareOcsMasterInventoryIntegrity(); console.log(r);\"",
    "audit:smoke": "node src/scripts/smokeApiAudit.js",
    "smoke:production-flows": "node src/scripts/productionFlowSmoke.js",
    "audit:push-audience": "node src/scripts/validatePushAudienceRouting.js",
    "audit:inventory-realtime": "node src/scripts/validateInventoryRealtimeRouting.js",
    "audit:sale-billing-linkage": "node src/scripts/validateSaleBillingLinkage.js",
    "audit:cross-device-stream": "node src/scripts/validateCrossDeviceInventoryStream.js",
    "purge:deleted-patients": "node src/scripts/purgeSoftDeletedPatients.js",
    "purge:patients-by-ids": "node src/scripts/purgePatientsByIds.js",
    "purge:deleted-team": "node src/scripts/purgeSoftDeletedTeamAccounts.js",
    "seed:doctor-stock": "node src/scripts/syncDoctorStockFromOcs.js",
    "clone:doctor-bag-template": "node src/scripts/cloneDoctorBagFromTemplate.js",
    "clone:davish-bag": "SOURCE_DOCTOR_USERNAME=dbalgobin node src/scripts/cloneDoctorBagFromTemplate.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
