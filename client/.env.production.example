# Build-time API URL when the frontend is hosted separately (e.g. Vercel)
# and the Express + SQLite backend runs on NAS/Docker.
#
# Example (Cloudflare named tunnel):
# VITE_API_BASE=https://ocs.example.com/api
#
# Leave unset when the UI is served from the same Docker container (default /api).

VITE_API_BASE=
